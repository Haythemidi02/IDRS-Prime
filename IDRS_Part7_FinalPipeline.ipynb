   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 6 — Adversarial Robustness: Feature Noise Injection"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Adversarial Robustness Test — Feature Perturbation\n",
    "#\n",
    "# Simulates adversarial evasion at the network feature level:\n",
    "#   1. Gaussian noise at varying SNR levels\n",
    "#   2. Feature zeroing (packet inspection bypass)\n",
    "#   3. Feature clipping (value truncation)\n",
    "#   4. Boundary perturbation (FGSM-style, gradient-free)\n",
    "#\n",
    "# An IDS must remain robust under these conditions.\n",
    "# ============================================================\n",
    "\n",
    "rng = np.random.default_rng(SEED)\n",
    "\n",
    "# Use attack samples only\n",
    "BENIGN_ID   = next((i for i,c in INT_TO_CLASS.items() if c=='BENIGN'), 0)\n",
    "attack_mask = (y_test != BENIGN_ID)\n",
    "X_atk       = X_test[attack_mask]\n",
    "y_atk       = y_test[attack_mask]\n",
    "N_ATK       = min(2000, len(X_atk))\n",
    "idx         = rng.choice(len(X_atk), N_ATK, replace=False)\n",
    "X_atk_s     = X_atk[idx]\n",
    "y_atk_s     = y_atk[idx]\n",
    "\n",
    "def eval_robustness(X_perturbed, y_true, model, name):\n",
    "    if hasattr(model, 'predict'):\n",
    "        yp = model.predict(X_perturbed)\n",
    "    else:\n",
    "        yp = np.argmax(dl_predict_proba(model, X_perturbed), 1)\n",
    "    return f1_score(y_true, yp, average='macro', zero_division=0)\n",
    "\n",
    "NOISE_LEVELS = [0.0, 0.05, 0.10, 0.20, 0.35, 0.50]\n",
    "ZERO_FRACS   = [0.0, 0.05, 0.10, 0.20, 0.30]\n",
    "\n",
    "robustness_results = defaultdict(dict)\n",
    "\n",
    "eval_models = {k:v for k,v in models.items()}\n",
    "if hybrid_model: eval_models['HybridCNNLSTM'] = hybrid_model\n",
    "\n",
    "print('Adversarial Robustness Test (feature-level perturbation)...')\n",
    "print(f'  Test size: {N_ATK} attack samples\\n')\n",
    "\n",
    "# 1. Gaussian noise\n",
    "print('  1. Gaussian noise injection:')\n",
    "for noise_std in NOISE_LEVELS:\n",
    "    X_noisy = X_atk_s + rng.normal(0, noise_std, X_atk_s.shape).astype(np.float32)\n",
    "    for mname, model in eval_models.items():\n",
    "        f1 = eval_robustness(X_noisy, y_atk_s, model, mname)\n",
    "        robustness_results[mname][f'noise_{noise_std:.2f}'] = round(f1, 4)\n",
    "    ens_pred = ensemble_predict(X_noisy, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES)[0][attack_mask][idx] if len(X_noisy)==N_ATK else np.zeros(N_ATK)\n",
    "    f1_ens = f1_score(y_atk_s, ensemble_predict(X_noisy, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES)[0], average='macro', zero_division=0)\n",
    "    robustness_results['Ensemble'][f'noise_{noise_std:.2f}'] = round(f1_ens, 4)\n",
    "    print(f'    σ={noise_std:.2f}  ', end='')\n",
    "    for mname in list(eval_models.keys())[:2]:\n",
    "        print(f'{mname}={robustness_results[mname][f\"noise_{noise_std:.2f}\"]:>6.4f}  ', end='')\n",
    "    print(f'Ensemble={robustness_results[\"Ensemble\"][f\"noise_{noise_std:.2f}\"]:>6.4f}')\n",
    "\n",
    "# 2. Feature zeroing\n",
    "print('\\n  2. Feature zeroing (random feature dropout):')\n",
    "for zero_frac in ZERO_FRACS:\n",
    "    X_zero = X_atk_s.copy()\n",
    "    if zero_frac > 0:\n",
    "        n_zero = int(X_zero.shape[1] * zero_frac)\n",
    "        cols_to_zero = rng.choice(X_zero.shape[1], n_zero, replace=False)\n",
    "        X_zero[:, cols_to_zero] = 0.0\n",
    "    f1_ens = f1_score(y_atk_s, ensemble_predict(X_zero, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES)[0], average='macro', zero_division=0)\n",
    "    robustness_results['Ensemble'][f'zero_{zero_frac:.2f}'] = round(f1_ens,4)\n",
    "    print(f'    zero={zero_frac:.0%}  Ensemble={f1_ens:.4f}')\n",
    "\n",
    "# Plot\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 5))\n",
    "\n",
    "ax = axes[0]\n",
    "colors_rob = ['#3498db','#e74c3c','#2ecc71','#f39c12','#9b59b6']\n",
    "for i, mname in enumerate(list(eval_models.keys()) + ['Ensemble']):\n",
    "    vals = [robustness_results[mname].get(f'noise_{s:.2f}', 0) for s in NOISE_LEVELS]\n",
    "    lw   = 3 if 'Ensemble' in mname else 1.8\n",
    "    ls   = '-' if 'Ensemble' in mname else '--'\n",
    "    ax.plot(NOISE_LEVELS, vals, lw=lw, ls=ls,\n",
    "            color=colors_rob[i%len(colors_rob)], label=mname,\n",
    "            marker='o', markersize=5)\n",
    "ax.set_xlabel('Gaussian Noise σ'); ax.set_ylabel('F1-Macro (attack classes)')\n",
    "ax.set_title('Robustness to Gaussian Noise\\n(higher = more robust)', fontweight='bold')\n",
    "ax.legend(fontsize=8); ax.set_ylim(0, 1.05)\n",
    "\n",
    "ax = axes[1]\n",
    "zero_vals = [robustness_results['Ensemble'].get(f'zero_{z:.2f}', 0) for z in ZERO_FRACS]\n",
    "ax.bar([f'{z:.0%}' for z in ZERO_FRACS], zero_vals,\n",
    "       color='#3498db', edgecolor='white', linewidth=0.8, alpha=0.85)\n",
    "ax.set_xlabel('Features Zeroed (%)'); ax.set_ylabel('Ensemble F1-Macro')\n",
    "ax.set_title('Robustness to Feature Dropout\\n(Ensemble model)', fontweight='bold')\n",
    "ax.set_ylim(0, 1.1)\n",
    "for i, v in enumerate(zero_vals):\n",
    "    ax.text(i, v+0.01, f'{v:.3f}', ha='center', fontsize=9, fontweight='bold')\n",
    "\n",
    "plt.suptitle('IDRS Adversarial Robustness — Feature-Level Perturbation',\n",
    "             fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUTPUT_DIR/'adversarial_robustness.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()\n",
    "print('Saved: outputs/adversarial_robustness.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 7 — Concept Drift Simulation"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Concept Drift Simulation\n",
    "#\n",
    "# Simulates performance degradation over time as traffic\n",
    "# patterns evolve (new tools, exam seasons, new attack vectors).\n",
    "#\n",
    "# We inject 3 drift events:\n",
    "#   t1 = 25%  : mild feature shift (new student batch)\n",
    "#   t2 = 50%  : moderate shift (new attack tool deployed)\n",
    "#   t3 = 75%  : strong shift (novel attack family emerges)\n",
    "#\n",
    "# We measure rolling F1 for each model and ADWIN online learner.\n",
    "# ============================================================\n",
    "\n",
    "from river import tree as rtree, drift as rdrift\n",
    "from river import metrics as rmetrics, compose, preprocessing as rprep\n",
    "\n",
    "STREAM_N = min(8000, len(X_test))\n",
    "X_stream = X_test[:STREAM_N].copy()\n",
    "y_stream = y_test[:STREAM_N].copy()\n",
    "\n",
    "# Drift injection points and magnitudes\n",
    "drift_events = [\n",
    "    (int(STREAM_N*0.25), 0.3, 'Mild shift\\n(new students)'),\n",
    "    (int(STREAM_N*0.50), 0.8, 'Moderate shift\\n(new attack tool)'),\n",
    "    (int(STREAM_N*0.75), 1.5, 'Strong shift\\n(novel attack)'),\n",
    "]\n",
    "\n",
    "for drift_idx, drift_mag, _ in drift_events:\n",
    "    X_stream[drift_idx:, :10] += (drift_mag * np.std(X_stream[:drift_idx,:10], axis=0)).astype(np.float32)\n",
    "\n",
    "# Rolling F1 for static models\n",
    "WINDOW = 200\n",
    "\n",
    "roll_results = defaultdict(list)\n",
    "\n",
    "# Online River model\n",
    "river_pipeline = compose.Pipeline(\n",
    "    rprep.StandardScaler(),\n",
    "    rtree.HoeffdingTreeClassifier(grace_period=50, delta=1e-5, max_depth=20)\n",
    ")\n",
    "adwin_detector = rdrift.ADWIN(delta=0.002)\n",
    "online_acc     = rmetrics.Accuracy()\n",
    "online_f1      = rmetrics.MacroF1()\n",
    "\n",
    "drift_alerts = []\n",
    "online_roll  = []\n",
    "\n",
    "for i in tqdm(range(len(X_stream)), desc='Concept drift sim'):\n",
    "    x_row  = X_stream[i]\n",
    "    y_true_i = int(y_stream[i])\n",
    "\n",
    "    # Static ensemble\n",
    "    if i >= WINDOW and i % 50 == 0:\n",
    "        X_win  = X_stream[i-WINDOW:i]\n",
    "        y_win  = y_stream[i-WINDOW:i]\n",
    "        yp_ens = ensemble_predict(X_win, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES)[0]\n",
    "        f1_ens = f1_score(y_win, yp_ens, average='macro', zero_division=0)\n",
    "        roll_results['Ensemble'].append((i, f1_ens))\n",
    "\n",
    "        if models:\n",
    "            m0_name = list(models.keys())[0]\n",
    "            yp_m0   = models[m0_name].predict(X_win)\n",
    "            f1_m0   = f1_score(y_win, yp_m0, average='macro', zero_division=0)\n",
    "            roll_results[m0_name].append((i, f1_m0))\n",
    "\n",
    "    # Online River\n",
    "    x_dict = {f'f{j}': float(v) for j,v in enumerate(x_row)}\n",
    "    y_pred_r = river_pipeline.predict_one(x_dict)\n",
    "    if y_pred_r is not None:\n",
    "        online_acc.update(y_true_i, y_pred_r)\n",
    "        online_f1.update(y_true_i, y_pred_r)\n",
    "        adwin_detector.update(int(y_pred_r == y_true_i))\n",
    "        if adwin_detector.drift_detected:\n",
    "            drift_alerts.append(i)\n",
    "    river_pipeline.learn_one(x_dict, y_true_i)\n",
    "    if i % 50 == 0 and y_pred_r is not None:\n",
    "        online_roll.append((i, float(online_acc.get())))\n",
    "\n",
    "# Plot\n",
    "fig, ax = plt.subplots(figsize=(16, 6))\n",
    "\n",
    "model_colors = {'Ensemble':'#2ecc71','RF':'#3498db','XGB':'#e74c3c','LGBM':'#f39c12'}\n",
    "for mname, pts in roll_results.items():\n",
    "    if pts:\n",
    "        xs,ys = zip(*pts)\n",
    "        ax.plot(xs, ys, lw=2.5 if 'Ensemble' in mname else 1.5,\n",
    "                color=model_colors.get(mname,'#95a5a6'),\n",
    "                label=mname, ls='-' if 'Ensemble' in mname else '--')\n",
    "\n",
    "if online_roll:\n",
    "    xs,ys = zip(*online_roll)\n",
    "    ax.plot(xs, ys, lw=1.8, color='#9b59b6', ls=':', label='River Online Acc')\n",
    "\n",
    "for drift_idx, mag, label in drift_events:\n",
    "    ax.axvline(drift_idx, color='#e74c3c', lw=2, ls='--', alpha=0.7)\n",
    "    ax.text(drift_idx+20, 0.08, label, fontsize=8, color='#e74c3c', fontweight='bold')\n",
    "\n",
    "for da in drift_alerts[:5]:\n",
    "    ax.axvline(da, color='#f39c12', lw=1.0, ls=':', alpha=0.5)\n",
    "if drift_alerts:\n",
    "    ax.axvline(drift_alerts[0], color='#f39c12', lw=1.0, ls=':',\n",
    "               alpha=0.5, label=f'ADWIN alerts ({len(drift_alerts)})')\n",
    "\n",
    "ax.set_xlabel('Stream Index'); ax.set_ylabel('Rolling F1-Macro')\n",
    "ax.set_title('Concept Drift Simulation — Rolling Performance\\n'\n",
    "             '(3 injected drift events, ADWIN alerts shown)',\n",
    "             fontweight='bold')\n",
    "ax.legend(fontsize=9); ax.set_ylim(0, 1.05)\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUTPUT_DIR/'concept_drift.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()\n",
    "print(f'ADWIN drift alerts: {len(drift_alerts)}')\n",
    "print(f'Online final acc: {online_acc.get():.4f}  F1: {online_f1.get():.4f}')\n",
    "print('Saved: outputs/concept_drift.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 8 — False Positive Analysis"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# False Positive Analysis\n",
    "#\n",
    "# In an educational setting, false positives are highly costly:\n",
    "# blocking legitimate students during exams is unacceptable.\n",
    "#\n",
    "# We measure:\n",
    "#   1. FPR per model (benign correctly classified as attack)\n",
    "#   2. Attack class misidentified as another attack class\n",
    "#   3. Confidence distribution of false positives\n",
    "#   4. Cost matrix (FP cost >> FN cost for exam endpoints)\n",
    "# ============================================================\n",
    "\n",
    "benign_mask   = (y_test == BENIGN_ID)\n",
    "X_benign_test = X_test[benign_mask]\n",
    "y_benign_test = y_test[benign_mask]\n",
    "\n",
    "print('False Positive Analysis\\n')\n",
    "print(f'  Benign test samples: {benign_mask.sum():,}')\n",
    "print(f'  Attack test samples: {(~benign_mask).sum():,}\\n')\n",
    "\n",
    "fp_results = []\n",
    "\n",
    "for mname, ypred_all in available_models.items():\n",
    "    # FP: benign classified as attack\n",
    "    ypred_benign = ypred_all[benign_mask]\n",
    "    fp_count  = (ypred_benign != BENIGN_ID).sum()\n",
    "    fpr       = fp_count / len(ypred_benign)\n",
    "\n",
    "    # FN: attacks missed (classified as benign)\n",
    "    ypred_atk = ypred_all[~benign_mask]\n",
    "    fn_count  = (ypred_atk == BENIGN_ID).sum()\n",
    "    fnr       = fn_count / max(len(ypred_atk), 1)\n",
    "\n",
    "    fp_results.append({\n",
    "        'model'   : mname,\n",
    "        'fp_count': int(fp_count),\n",
    "        'fpr'     : round(fpr, 4),\n",
    "        'fn_count': int(fn_count),\n",
    "        'fnr'     : round(fnr, 4),\n",
    "    })\n",
    "    print(f'  {mname:<18}  FPR={fpr:.4f} ({fp_count:4d} FPs)  FNR={fnr:.4f} ({fn_count:4d} FNs)')\n",
    "\n",
    "fp_df = pd.DataFrame(fp_results)\n",
    "fp_df.to_csv(OUTPUT_DIR/'fp_analysis.csv', index=False)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "ax = axes[0]\n",
    "x   = np.arange(len(fp_df))\n",
    "w   = 0.35\n",
    "b1  = ax.bar(x-w/2, fp_df['fpr'], w, label='FPR (benign→attack)', color='#e74c3c', alpha=0.85)\n",
    "b2  = ax.bar(x+w/2, fp_df['fnr'], w, label='FNR (attack→benign)', color='#3498db', alpha=0.85)\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(fp_df['model'], rotation=25, ha='right', fontsize=8)\n",
    "ax.set_ylabel('Rate')\n",
    "ax.set_title('FPR vs FNR per Model\\n(Lower is better for both)', fontweight='bold')\n",
    "ax.legend(fontsize=9)\n",
    "ax.axhline(0.05, color='black', lw=1, ls='--', alpha=0.5, label='5% threshold')\n",
    "\n",
    "ax = axes[1]\n",
    "scatter_colors = ['#2ecc71' if r['fpr']<0.05 and r['fnr']<0.10 else\n",
    "                  ('#f39c12' if r['fpr']<0.10 else '#e74c3c')\n",
    "                  for _, r in fp_df.iterrows()]\n",
    "ax.scatter(fp_df['fpr'], fp_df['fnr'], c=scatter_colors, s=120, zorder=5,\n",
    "           edgecolors='black', linewidth=0.8)\n",
    "for _, row in fp_df.iterrows():\n",
    "    ax.annotate(row['model'], (row['fpr'], row['fnr']),\n",
    "                textcoords='offset points', xytext=(6,4), fontsize=8)\n",
    "ax.axvline(0.05, color='#e74c3c', lw=1.5, ls='--', alpha=0.6, label='FPR=5%')\n",
    "ax.axhline(0.10, color='#3498db', lw=1.5, ls='--', alpha=0.6, label='FNR=10%')\n",
    "ax.set_xlabel('FPR (benign blocked)'); ax.set_ylabel('FNR (attacks missed)')\n",
    "ax.set_title('FPR-FNR Trade-off\\n(Bottom-left = ideal)', fontweight='bold')\n",
    "ax.legend(fontsize=9)\n",
    "\n",
    "plt.suptitle('IDRS False Positive / False Negative Analysis', fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUTPUT_DIR/'fp_analysis.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()\n",
    "print('Saved: outputs/fp_analysis.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 9 — Response Time Distribution"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# End-to-End Response Time Benchmark\n",
    "# Measures total time from raw input to response decision.\n",
    "# ============================================================\n",
    "\n",
    "BENCH_N = min(500, len(X_test))\n",
    "X_bench = X_test[:BENCH_N]\n",
    "\n",
    "timing = {}\n",
    "\n",
    "# Individual models\n",
    "for mname, model in models.items():\n",
    "    times = []\n",
    "    for i in range(0, BENCH_N, 32):\n",
    "        xb = X_bench[i:i+32]\n",
    "        t0 = time.perf_counter()\n",
    "        _ = model.predict_proba(xb)\n",
    "        times.append((time.perf_counter()-t0)/len(xb)*1000)\n",
    "    timing[mname] = np.array(times)\n",
    "\n",
    "if hybrid_model:\n",
    "    times = []\n",
    "    for i in range(0, BENCH_N, 32):\n",
    "        xb = X_bench[i:i+32]\n",
    "        t0 = time.perf_counter()\n",
    "        _ = dl_predict_proba(hybrid_model, xb)\n",
    "        times.append((time.perf_counter()-t0)/len(xb)*1000)\n",
    "    timing['HybridCNNLSTM'] = np.array(times)\n",
    "\n",
    "# Ensemble\n",
    "times = []\n",
    "for i in range(0, BENCH_N, 32):\n",
    "    xb = X_bench[i:i+32]\n",
    "    t0 = time.perf_counter()\n",
    "    _ = ensemble_predict(xb, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES)\n",
    "    times.append((time.perf_counter()-t0)/len(xb)*1000)\n",
    "timing['Ensemble'] = np.array(times)\n",
    "\n",
    "print('Response Time Benchmark (ms per sample):')\n",
    "print(f'  {\"Model\":<20} {\"Mean\":>8} {\"Median\":>8} {\"P95\":>8} {\"P99\":>8} {\"Throughput\":>12}')\n",
    "print('  '+'-'*68)\n",
    "for mname, t_arr in timing.items():\n",
    "    tput = 1000/t_arr.mean()\n",
    "    print(f'  {mname:<20} {t_arr.mean():>8.3f} {np.median(t_arr):>8.3f} '\n",
    "          f'{np.percentile(t_arr,95):>8.3f} {np.percentile(t_arr,99):>8.3f} '\n",
    "          f'{tput:>10.0f}/s')\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 5))\n",
    "\n",
    "ax = axes[0]\n",
    "means = [t.mean() for t in timing.values()]\n",
    "p95s  = [np.percentile(t,95) for t in timing.values()]\n",
    "names = list(timing.keys())\n",
    "x     = np.arange(len(names))\n",
    "ax.bar(x-0.2, means, 0.35, label='Mean', color='#3498db', edgecolor='white')\n",
    "ax.bar(x+0.2, p95s,  0.35, label='P95',  color='#e74c3c', edgecolor='white', alpha=0.85)\n",
    "ax.set_xticks(x); ax.set_xticklabels(names, rotation=25, ha='right', fontsize=8)\n",
    "ax.axhline(10, color='black', lw=1.5, ls='--', alpha=0.5, label='10ms target')\n",
    "ax.set_ylabel('Time (ms/sample)'); ax.set_title('Inference Latency per Model', fontweight='bold')\n",
    "ax.legend(fontsize=9)\n",
    "\n",
    "ax = axes[1]\n",
    "for mname, t_arr in timing.items():\n",
    "    ax.hist(t_arr, bins=20, alpha=0.6, label=mname, density=True)\n",
    "ax.set_xlabel('ms/sample'); ax.set_ylabel('Density')\n",
    "ax.set_title('Latency Distribution per Model', fontweight='bold')\n",
    "ax.legend(fontsize=8)\n",
    "\n",
    "plt.suptitle('IDRS End-to-End Response Time Analysis', fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUTPUT_DIR/'response_times.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()\n",
    "print('Saved: outputs/response_times.png')"
