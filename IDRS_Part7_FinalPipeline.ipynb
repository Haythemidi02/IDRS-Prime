   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 10 — Serialise Full Pipeline"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Serialise the complete IDRS inference pipeline.\n",
    "# Output: a single callable that accepts raw feature vectors\n",
    "# and returns (threat_class, confidence, severity, actions).\n",
    "# ============================================================\n",
    "\n",
    "class IDRSPipeline:\n",
    "    \"\"\"\n",
    "    Deployable IDRS inference pipeline.\n",
    "    Wraps all models into a single .predict() interface.\n",
    "    \"\"\"\n",
    "    def __init__(self, scaler, classical_models, dl_model,\n",
    "                 ae_model, ensemble_weights, class_names,\n",
    "                 feature_cols, anomaly_cfg):\n",
    "        self.scaler           = scaler\n",
    "        self.classical_models = classical_models\n",
    "        self.dl_model         = dl_model\n",
    "        self.ae_model         = ae_model\n",
    "        self.ensemble_weights = ensemble_weights\n",
    "        self.class_names      = class_names\n",
    "        self.feature_cols     = feature_cols\n",
    "        self.anomaly_cfg      = anomaly_cfg\n",
    "        self.n_classes        = len(class_names)\n",
    "\n",
    "    def predict(self, X_raw: np.ndarray) -> Dict:\n",
    "        \"\"\"\n",
    "        Full pipeline prediction.\n",
    "        X_raw: (N, N_FEATURES) unscaled feature matrix.\n",
    "        Returns dict with predictions, probabilities, anomaly scores.\n",
    "        \"\"\"\n",
    "        t0  = time.perf_counter()\n",
    "\n",
    "        # Scale\n",
    "        X   = self.scaler.transform(X_raw) if self.scaler else X_raw\n",
    "\n",
    "        # Ensemble predict\n",
    "        y_pred, y_prob, _ = ensemble_predict(\n",
    "            X, self.classical_models,\n",
    "            self.dl_model, self.ae_model,\n",
    "            self.anomaly_cfg, self.n_classes\n",
    "        )\n",
    "\n",
    "        # Anomaly scores\n",
    "        ad_scores = np.zeros(len(X))\n",
    "        if self.ae_model:\n",
    "            ad_scores = ae_anomaly_scores(self.ae_model, X)\n",
    "\n",
    "        latency = (time.perf_counter()-t0)*1000\n",
    "\n",
    "        return {\n",
    "            'predictions'    : y_pred,\n",
    "            'class_names'    : [self.class_names[p] for p in y_pred],\n",
    "            'probabilities'  : y_prob,\n",
    "            'confidence'     : y_prob.max(axis=1),\n",
    "            'anomaly_scores' : ad_scores,\n",
    "            'latency_ms'     : latency,\n",
    "            'n_samples'      : len(X),\n",
    "        }\n",
    "\n",
    "    def predict_single(self, x_raw: np.ndarray) -> Dict:\n",
    "        \"\"\"Predict for a single sample.\"\"\"\n",
    "        result = self.predict(x_raw.reshape(1, -1))\n",
    "        return {\n",
    "            'threat_class': result['class_names'][0],\n",
    "            'confidence'  : float(result['confidence'][0]),\n",
    "            'probabilities': dict(zip(self.class_names,\n",
    "                                      result['probabilities'][0].tolist())),\n",
    "            'anomaly_score': float(result['anomaly_scores'][0]),\n",
    "            'latency_ms'  : result['latency_ms'],\n",
    "        }\n",
    "\n",
    "\n",
    "# Build pipeline\n",
    "idrs_pipeline = IDRSPipeline(\n",
    "    scaler           = scaler,\n",
    "    classical_models = models,\n",
    "    dl_model         = hybrid_model,\n",
    "    ae_model         = ae_model,\n",
    "    ensemble_weights = ENSEMBLE_WEIGHTS_BASE,\n",
    "    class_names      = CLASS_NAMES,\n",
    "    feature_cols     = FEATURE_COLS,\n",
    "    anomaly_cfg      = anomaly_cfg,\n",
    ")\n",
    "\n",
    "# Quick test\n",
    "sample_result = idrs_pipeline.predict_single(X_test[0])\n",
    "print(f'✅ Pipeline test:')\n",
    "print(f'   Threat  : {sample_result[\"threat_class\"]}')\n",
    "print(f'   Conf    : {sample_result[\"confidence\"]:.4f}')\n",
    "print(f'   Latency : {sample_result[\"latency_ms\"]:.2f}ms')\n",
    "\n",
    "# Serialise\n",
    "pipeline_path = MODEL_DIR / 'idrs_full_pipeline.joblib'\n",
    "joblib.dump(idrs_pipeline, pipeline_path)\n",
    "size_mb = pipeline_path.stat().st_size / 1e6\n",
    "print(f'\\n💾 Full pipeline saved: {pipeline_path}  ({size_mb:.1f} MB)')"
   ]
  },
