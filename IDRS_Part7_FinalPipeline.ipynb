   "source": ["## CELL 5 — Per-Class Detection Rate Heatmap"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Per-class recall (detection rate) for each model.\n",
    "# Most critical metric for an IDS: are we catching all attacks?\n",
    "# ============================================================\n",
    "\n",
    "available_models = {}\n",
    "for name, model in models.items():\n",
    "    available_models[name] = model.predict(X_test)\n",
    "if hybrid_model is not None:\n",
    "    available_models['HybridCNNLSTM'] = np.argmax(dl_predict_proba(hybrid_model, X_test), 1)\n",
    "available_models['IDRS-Ensemble'] = y_pred_ens\n",
    "\n",
    "recall_matrix = {}\n",
    "for mname, ypred in available_models.items():\n",
