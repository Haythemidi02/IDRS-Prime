   "source": ["## CELL 2 — Load All Trained Models"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Load all serialised models from Parts 2, 3, 4, 5\n",
    "# Graceful fallback if any checkpoint is missing\n",
    "# ============================================================\n",
    "\n",
    "# Re-import architectures from Part 3 (paste or import)\n",
    "# For standalone use, the architecture classes must be defined.\n",
    "# In a real deployment these would be imported from idrs_models.py\n",
    "\n",
    "import torch.nn as nn\n",
    "\n",
    "class AttentionPooling(nn.Module):\n",
    "    def __init__(self, h):\n",
    "        super().__init__()\n",
    "        self.attn = nn.Sequential(nn.Linear(h,h//2),nn.Tanh(),nn.Linear(h//2,1))\n",
    "    def forward(self, x):\n",
    "        w = torch.softmax(self.attn(x), dim=1)\n",
    "        return (x*w).sum(dim=1)\n",
    "\n",
    "class MultiHeadSelfAttention(nn.Module):\n",
    "    def __init__(self, d, heads=4, drop=0.1):\n",
    "        super().__init__()\n",
    "        self.attn = nn.MultiheadAttention(d, heads, dropout=drop, batch_first=True)\n",
    "        self.norm = nn.LayerNorm(d)\n",
    "    def forward(self, x):\n",
    "        out, _ = self.attn(x,x,x,need_weights=False)\n",
    "        return self.norm(x+out)\n",
    "\n",
    "class HybridCNNLSTM(nn.Module):\n",
    "    def __init__(self, n_features, n_classes, cnn_ch=128, lstm_h=256, lstm_l=2, heads=4, drop=0.3):\n",
    "        super().__init__()\n",
    "        self.cnn = nn.Sequential(\n",
    "            nn.Conv1d(1,64,5,padding=2,bias=False),nn.BatchNorm1d(64),nn.GELU(),nn.Dropout(drop*0.5),\n",
    "            nn.Conv1d(64,cnn_ch,3,padding=1,bias=False),nn.BatchNorm1d(cnn_ch),nn.GELU(),nn.MaxPool1d(2),\n",
    "            nn.Conv1d(cnn_ch,cnn_ch,3,padding=1,bias=False),nn.BatchNorm1d(cnn_ch),nn.GELU(),nn.Dropout(drop*0.5),\n",
    "        )\n",
    "        self.lstm = nn.LSTM(cnn_ch,lstm_h,lstm_l,batch_first=True,bidirectional=True,\n",
    "                            dropout=drop if lstm_l>1 else 0.0)\n",
    "        self.mhsa = MultiHeadSelfAttention(lstm_h*2,heads,drop*0.3)\n",
    "        self.pool = AttentionPooling(lstm_h*2)\n",
    "        self.head = nn.Sequential(\n",
    "            nn.Linear(lstm_h*2,256),nn.LayerNorm(256),nn.GELU(),nn.Dropout(drop),\n",
    "            nn.Linear(256,128),nn.GELU(),nn.Dropout(drop*0.5),\n",
    "            nn.Linear(128,n_classes)\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        c = self.cnn(x)\n",
    "        l,_ = self.lstm(c.permute(0,2,1))\n",
    "        a = self.mhsa(l)\n",
    "        return self.head(self.pool(a))\n",
    "\n",
    "class IDRSAutoencoder(nn.Module):\n",
    "    def __init__(self, n_features, latent=32, drop=0.15):\n",
    "        super().__init__()\n",
    "        def eb(i,o): return nn.Sequential(nn.Linear(i,o),nn.BatchNorm1d(o),nn.GELU(),nn.Dropout(drop))\n",
    "        self.e1=eb(n_features,256); self.e2=eb(256,128); self.e3=eb(128,64)\n",
    "        self.e4=nn.Sequential(nn.Linear(64,latent),nn.Tanh())\n",
    "        def db(i,o,last=False): return nn.Sequential(nn.Linear(i,o)) if last else nn.Sequential(nn.Linear(i,o),nn.BatchNorm1d(o),nn.GELU(),nn.Dropout(drop))\n",
    "        self.d4=db(latent,64); self.d3=db(64+64,128); self.d2=db(128+128,256); self.d1=db(256+256,n_features)\n",
    "        self.out=nn.Linear(n_features,n_features)\n",
    "    def forward(self, x):\n",
    "        h1=self.e1(x); h2=self.e2(h1); h3=self.e3(h2); z=self.e4(h3)\n",
    "        d4=self.d4(z); d3=self.d3(torch.cat([d4,h3],-1)); d2=self.d2(torch.cat([d3,h2],-1))\n",
    "        d1=self.d1(torch.cat([d2,h1],-1))\n",
    "        return self.out(d1), z\n",
    "\n",
    "# --- Load classical models ---\n",
    "models = {}\n",
    "for name, fname in [('RF','rf_best.joblib'),('XGB','xgb_best.joblib'),('LGBM','lgbm_best.joblib')]:\n",
    "    p = MODEL_DIR/fname\n",
    "    if p.exists():\n",
    "        models[name] = joblib.load(p)\n",
    "        print(f'✅ Loaded {name}')\n",
    "    else:\n",
    "        print(f'⚠️  {name} not found — run Part 2 first')\n",
    "\n",
    "# --- Load scaler ---\n",
    "scaler_path = MODEL_DIR/'scaler.joblib'\n",
    "scaler = joblib.load(scaler_path) if scaler_path.exists() else None\n",
    "print(f'✅ Scaler loaded' if scaler else '⚠️  Scaler not found')\n",
    "\n",
    "# --- Load Hybrid CNN-LSTM ---\n",
    "hl_path = MODEL_DIR/'hybridcnnlstm.pt'\n",
    "hybrid_model = None\n",
    "if hl_path.exists():\n",
    "    ck = torch.load(hl_path, map_location=DEVICE)\n",
    "    hybrid_model = HybridCNNLSTM(N_FEATURES, N_CLASSES).to(DEVICE)\n",
    "    hybrid_model.load_state_dict(ck['model_state'])\n",
    "    hybrid_model.eval()\n",
    "    print(f'✅ Loaded HybridCNNLSTM (best_epoch={ck.get(\"best_epoch\",\"?\")})')\n",
    "else:\n",
    "    print('⚠️  HybridCNNLSTM not found — run Part 3 first')\n",
    "\n",
    "# --- Load Autoencoder ---\n",
    "ae_path = MODEL_DIR/'autoencoder.pt'\n",
    "ae_model = None\n",
    "if ae_path.exists():\n",
    "    ck = torch.load(ae_path, map_location=DEVICE)\n",
    "    ae_model = IDRSAutoencoder(N_FEATURES, ck.get('latent_dim',32)).to(DEVICE)\n",
    "    ae_model.load_state_dict(ck['model_state'])\n",
    "    ae_model.eval()\n",
    "    print(f'✅ Loaded Autoencoder (best_val_mse={ck.get(\"best_val_mse\",\"?\"):.6f})')\n",
    "else:\n",
    "    print('⚠️  Autoencoder not found — run Part 4 first')\n",
    "\n",
    "# --- Load anomaly ensemble config ---\n",
    "ae_cfg_path = MODEL_DIR/'anomaly_ensemble_cfg.json'\n",
    "anomaly_cfg = load_json(ae_cfg_path)\n",
    "\n",
    "# --- Load test data ---\n",
    "X_test = np.load(OUTPUT_DIR/'X_test_scaled.npy').astype(np.float32)\n",
    "y_test = np.load(OUTPUT_DIR/'y_test.npy').astype(np.int64)\n",
    "print(f'\\n✅ Test set: {X_test.shape}  classes={np.unique(y_test)}')"
   ]
