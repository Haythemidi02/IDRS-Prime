   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 4 — Final Benchmark: All Models"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Collect all model metrics and build the master comparison table\n",
    "# ============================================================\n",
    "\n",
    "def compute_all_metrics(y_true, y_pred, y_prob, name, split='Test'):\n",
    "    y_bin = label_binarize(y_true, classes=list(range(N_CLASSES)))\n",
    "    try:\n",
    "        auc = roc_auc_score(y_bin, y_prob, average='macro', multi_class='ovr')\n",
    "    except:\n",
    "        auc = float('nan')\n",
    "    pr_aucs = [average_precision_score(y_bin[:,c], y_prob[:,c])\n",
    "               for c in range(N_CLASSES) if y_bin[:,c].sum()>0]\n",
    "    return {\n",
    "        'model'         : name,\n",
    "        'accuracy'      : round(accuracy_score(y_true, y_pred), 4),\n",
    "        'balanced_acc'  : round(balanced_accuracy_score(y_true, y_pred), 4),\n",
    "        'f1_macro'      : round(f1_score(y_true, y_pred, average='macro',    zero_division=0), 4),\n",
    "        'f1_weighted'   : round(f1_score(y_true, y_pred, average='weighted', zero_division=0), 4),\n",
    "        'precision_macro':round(precision_score(y_true, y_pred, average='macro', zero_division=0), 4),\n",
    "        'recall_macro'  : round(recall_score(y_true, y_pred, average='macro',    zero_division=0), 4),\n",
    "        'roc_auc'       : round(auc, 4),\n",
    "        'pr_auc'        : round(float(np.mean(pr_aucs)), 4),\n",
    "        'mcc'           : round(matthews_corrcoef(y_true, y_pred), 4),\n",
    "    }\n",
    "\n",
    "all_metrics = []\n",
    "\n",
    "# --- Classical models ---\n",
    "for name, model in models.items():\n",
    "    yp  = model.predict(X_test)\n",
    "    ypr = model.predict_proba(X_test)\n",
    "    all_metrics.append(compute_all_metrics(y_test, yp, ypr, name))\n",
    "\n",
    "# --- Deep CNN-LSTM ---\n",
    "if hybrid_model is not None:\n",
    "    ypr = dl_predict_proba(hybrid_model, X_test)\n",
    "    yp  = np.argmax(ypr, axis=1)\n",
    "    all_metrics.append(compute_all_metrics(y_test, yp, ypr, 'HybridCNNLSTM'))\n",
    "\n",
    "# --- Ensemble ---\n",
    "all_metrics.append(compute_all_metrics(y_test, y_pred_ens, y_prob_ens, 'IDRS-Ensemble'))\n",
    "\n",
    "# --- Load Part 2/3 stored metrics ---\n",
    "for reg, names in [(classical_reg, ['RandomForest','XGBoost','LightGBM']),\n",
    "                   (deep_reg, ['CNN1D','BiLSTM'])]:\n",
    "    for n in names:\n",
    "        if n in reg and 'test_f1' in reg[n]:\n",
    "            existing_names = [m['model'] for m in all_metrics]\n",
    "            short = n.replace('Random','RF').replace('Forest','').replace(' ','')\n",
    "            if n not in existing_names and short not in existing_names:\n",
    "                all_metrics.append({\n",
    "                    'model': n,\n",
    "                    'f1_macro': reg[n].get('test_f1', 0),\n",
    "                    'roc_auc' : reg[n].get('test_auc',0),\n",
    "                    'accuracy':0,'balanced_acc':0,'f1_weighted':0,\n",
    "                    'precision_macro':0,'recall_macro':0,'pr_auc':0,'mcc':0,\n",
    "                })\n",
    "\n",
    "bench_df = pd.DataFrame(all_metrics)\n",
    "bench_df = bench_df.sort_values('f1_macro', ascending=False).reset_index(drop=True)\n",
    "bench_df.to_csv(OUTPUT_DIR/'master_benchmark.csv', index=False)\n",
    "\n",
    "print('\\n MASTER BENCHMARK TABLE — All Models (Test Set)')\n",
    "print('='*95)\n",
    "cols = ['model','accuracy','balanced_acc','f1_macro','f1_weighted',\n",
    "        'recall_macro','roc_auc','pr_auc','mcc']\n",
    "cols = [c for c in cols if c in bench_df.columns]\n",
    "print(bench_df[cols].to_string(index=False))\n",
    "\n",
    "best = bench_df.iloc[0]\n",
    "print(f'\\n🥇 Best: {best[\"model\"]}  F1={best[\"f1_macro\"]:.4f}  AUC={best[\"roc_auc\"]:.4f}')"
   ]
  },
