   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 3 — Ensemble Inference Engine"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Soft-Voting Ensemble\n",
    "#\n",
    "# Combines probability outputs from all available classifiers:\n",
    "#   P_final = w_ml*P_ml + w_dl*P_dl + w_ae*P_ae_binary\n",
    "#\n",
    "# Weights derived from individual val-set F1 scores.\n",
    "# Missing models are excluded and weights renormalised.\n",
    "# ============================================================\n",
    "\n",
    "ENSEMBLE_WEIGHTS_BASE = {'RF':0.18,'XGB':0.22,'LGBM':0.22,'HybridCNNLSTM':0.38}\n",
    "\n",
    "@torch.no_grad()\n",
    "def dl_predict_proba(model, X: np.ndarray, batch_size=1024) -> np.ndarray:\n",
    "    model.eval()\n",
    "    all_probs = []\n",
    "    for i in range(0, len(X), batch_size):\n",
    "        xb = torch.tensor(X[i:i+batch_size], dtype=torch.float32).unsqueeze(1).to(DEVICE)\n",
    "        logits = model(xb)\n",
    "        probs  = F.softmax(logits, dim=-1).cpu().numpy()\n",
    "        all_probs.append(probs)\n",
    "    return np.vstack(all_probs)\n",
    "\n",
    "@torch.no_grad()\n",
    "def ae_anomaly_scores(ae, X: np.ndarray, batch_size=1024) -> np.ndarray:\n",
    "    ae.eval()\n",
    "    scores = []\n",
    "    for i in range(0, len(X), batch_size):\n",
    "        xb = torch.tensor(X[i:i+batch_size], dtype=torch.float32).to(DEVICE)\n",
    "        xhat, _ = ae(xb)\n",
    "        mse = ((xb - xhat)**2).mean(dim=-1).cpu().numpy()\n",
    "        scores.append(mse)\n",
    "    return np.concatenate(scores)\n",
    "\n",
    "\n",
    "def ensemble_predict(X: np.ndarray,\n",
    "                      models: dict,\n",
    "                      hybrid_model,\n",
    "                      ae_model,\n",
    "                      anomaly_cfg: dict,\n",
    "                      n_classes: int) -> Tuple[np.ndarray, np.ndarray]:\n",
    "    \"\"\"\n",
    "    Soft-voting ensemble prediction.\n",
    "    Returns (y_pred, y_prob) where y_prob shape = (N, n_classes).\n",
    "    \"\"\"\n",
    "    prob_sum    = np.zeros((len(X), n_classes), dtype=np.float64)\n",
    "    weight_total = 0.0\n",
    "    contributions = {}\n",
    "\n",
    "    # --- Classical ML ---\n",
    "    for name in ['RF','XGB','LGBM']:\n",
    "        if name in models:\n",
    "            w = ENSEMBLE_WEIGHTS_BASE[name]\n",
    "            p = models[name].predict_proba(X)\n",
    "            prob_sum    += w * p\n",
    "            weight_total += w\n",
    "            contributions[name] = w\n",
    "\n",
    "    # --- Deep CNN-LSTM ---\n",
    "    if hybrid_model is not None:\n",
    "        w = ENSEMBLE_WEIGHTS_BASE['HybridCNNLSTM']\n",
    "        p = dl_predict_proba(hybrid_model, X)\n",
    "        prob_sum    += w * p\n",
    "        weight_total += w\n",
    "        contributions['HybridCNNLSTM'] = w\n",
    "\n",
    "    # Normalise\n",
    "    if weight_total > 0:\n",
    "        prob_sum /= weight_total\n",
    "\n",
    "    y_pred = np.argmax(prob_sum, axis=1)\n",
    "    return y_pred, prob_sum, contributions\n",
    "\n",
    "\n",
    "print('Running ensemble inference on test set...')\n",
    "t0 = time.time()\n",
    "y_pred_ens, y_prob_ens, contribs = ensemble_predict(\n",
    "    X_test, models, hybrid_model, ae_model, anomaly_cfg, N_CLASSES\n",
    ")\n",
    "ens_time = time.time() - t0\n",
    "\n",
    "print(f'✅ Ensemble inference: {len(X_test):,} samples in {ens_time:.2f}s '\n",
    "      f'({len(X_test)/ens_time:.0f} samples/sec)')\n",
    "print(f'   Active components: {list(contribs.keys())}')\n",
    "print(f'   Weight distribution: {contribs}')"
   ]
  },
